{
  "manifest_version": 3,
  "name": "MV3 Architecture Stress Test",
  "version": "1.0.0",
  "description": "A least-privilege MV3 test manifest for lifecycle, messaging, DNR, and local formula rendering.",
  "action": {
    "default_title": "MV3 Test Tools",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "declarativeNetRequest",
    "scripting",
    "storage",
    "tabs"
  ],
  "optional_host_permissions": [
    "https://*.example.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "work-hours-blocking",
        "enabled": false,
        "path": "rules.json"
      }
    ]
  }
}
