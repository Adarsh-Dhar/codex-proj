{
  "manifest_version": 3,
  "name": "Wallet Status",
  "version": "1.0.0",
  "description": "Connect your EVM wallet and view current API status.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://api.example.com/*"
  ]
}
