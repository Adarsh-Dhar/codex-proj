{
  "manifest_version": 3,
  "name": "BTC Tracker",
  "version": "1.0.0",
  "description": "Logs the Bitcoin price every five minutes.",
  "permissions": [
    "alarms"
  ],
  "host_permissions": [
    "https://api.coindesk.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
